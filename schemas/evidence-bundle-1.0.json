{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://chariot.opencdx.io/schemas/evidence-bundle-1.0.json",
  "title": "Evidence Bundle Manifest",
  "description": "Schema for packaged evidence bundle manifests",
  "type": "object",
  "required": ["bundle_id", "source_run_id", "created_at", "contents", "hash"],
  "properties": {
    "bundle_id": { "type": "string" },
    "source_run_id": { "type": "string" },
    "created_at": { "type": "string", "format": "date-time" },
    "redacted": { "type": "boolean" },
    "contents": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["path", "sha256", "size_bytes"],
        "properties": {
          "path": { "type": "string" },
          "sha256": { "type": "string", "pattern": "^[a-f0-9]{64}$" },
          "size_bytes": { "type": "integer", "minimum": 0 },
          "role": { "type": "string" }
        }
      }
    },
    "hash": {
      "type": "object",
      "required": ["algorithm", "value"],
      "properties": {
        "algorithm": { "type": "string", "enum": ["sha256"] },
        "value": { "type": "string" }
      }
    },
    "provenance": {
      "type": "object",
      "properties": {
        "module": { "type": "string" },
        "phase": { "type": "string" },
        "source": { "type": "string" },
        "version": { "type": "string" }
      }
    }
  }
}
