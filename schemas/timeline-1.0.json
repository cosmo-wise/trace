{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://chariot.opencdx.io/schemas/timeline-1.0.json",
  "title": "Trace Timeline Event",
  "description": "Schema for each line in timeline.jsonl",
  "type": "object",
  "required": ["event_id", "run_id", "timestamp", "type", "module", "phase", "status", "message"],
  "properties": {
    "event_id": { "type": "string", "pattern": "^[\\w-]+$" },
    "run_id": { "type": "string", "pattern": "^[\\w.-]+$" },
    "timestamp": { "type": "string", "format": "date-time" },
    "type": { "type": "string" },
    "module": { "type": "string" },
    "phase": { "type": "string" },
    "status": { "type": "string", "enum": ["ok", "warning", "error", "info", "skipped"] },
    "message": { "type": "string" },
    "metadata": { "type": "object" },
    "source_path": { "type": "string" },
    "trace_path": { "type": "string" },
    "sha256": { "type": "string", "pattern": "^[a-f0-9]{64}$" },
    "size_bytes": { "type": "integer", "minimum": 0 },
    "artifact_id": { "type": "string" },
    "artifact_type": { "type": "string" },
    "role": { "type": "string" },
    "sensitivity_level": {
      "type": "string",
      "enum": ["public", "internal", "confidential", "restricted"]
    },
    "provenance": {
      "type": "object",
      "properties": {
        "module": { "type": "string" },
        "phase": { "type": "string" },
        "source": { "type": "string" },
        "version": { "type": "string" }
      }
    }
  }
}
