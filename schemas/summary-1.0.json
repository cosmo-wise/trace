{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://chariot.opencdx.io/schemas/summary-1.0.json",
  "title": "Trace Run Summary",
  "description": "Schema for run summary.json (consumed by compass, stirrup)",
  "type": "object",
  "required": ["run_id", "status", "modules", "artifacts", "events"],
  "properties": {
    "version": { "type": "integer", "minimum": 1 },
    "run_id": { "type": "string" },
    "status": { "type": "string" },
    "label": { "type": "string" },
    "started_at": { "type": "string", "format": "date-time" },
    "completed_at": { "type": "string", "format": "date-time" },
    "modules": { "type": "object" },
    "artifacts": {
      "type": "object",
      "properties": {
        "total": { "type": "integer", "minimum": 0 },
        "by_type": { "type": "object" },
        "total_bytes": { "type": "integer", "minimum": 0 }
      }
    },
    "events": {
      "type": "object",
      "properties": {
        "total": { "type": "integer", "minimum": 0 },
        "by_status": { "type": "object" }
      }
    },
    "module_health": { "type": "object" },
    "sensitivity_level": {
      "type": "string",
      "enum": ["public", "internal", "confidential", "restricted"]
    },
    "provenance": {
      "type": "object",
      "properties": {
        "module": { "type": "string" },
        "phase": { "type": "string" },
        "source": { "type": "string" },
        "version": { "type": "string" }
      }
    }
  }
}
